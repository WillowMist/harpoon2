# Harpoon2 Environment Configuration
# Copy this file to .env and update with your values
# The .env file will be loaded automatically by docker-compose

# Django Settings
DEBUG=False
SECRET_KEY=your-secure-secret-key-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,harpoon2,your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com

# Redis Configuration
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
